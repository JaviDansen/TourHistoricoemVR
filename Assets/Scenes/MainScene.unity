  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "O Armaz\xE9m Dona Tet\xE9 foi utilizado como espa\xE7o de armazenamento
    e circula\xE7\xE3o de mercadorias durante o funcionamento do Complexo Trapiche
    Santo \xC2ngelo.\nA regi\xE3o portu\xE1ria de S\xE3o Lu\xEDs possu\xEDa grande
    import\xE2ncia comercial, funcionando como ponto estrat\xE9gico para movimenta\xE7\xE3o
    de produtos e atividades econ\xF4micas da cidade. Os armaz\xE9ns desempenhavam
    papel fundamental nesse processo, auxiliando no funcionamento das opera\xE7\xF5es
    comerciais da \xE9poca.\nHoje, o espa\xE7o permanece como parte importante da
    mem\xF3ria hist\xF3rica e cultural do Trapiche, ajudando a preservar a identidade
    arquitet\xF4nica e patrimonial da regi\xE3o."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
