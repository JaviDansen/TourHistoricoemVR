  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "As chamin\xE9s do Trapiche representam uma importante parte do passado
    industrial e portu\xE1rio de S\xE3o Lu\xEDs. Durante muitos anos, essa regi\xE3o
    foi utilizada para atividades comerciais ligadas ao transporte e armazenamento
    de mercadorias.\nAl\xE9m de fazerem parte da estrutura industrial do local, as
    chamin\xE9s tornaram-se s\xEDmbolos hist\xF3ricos da antiga movimenta\xE7\xE3o
    econ\xF4mica do Trapiche Santo \xC2ngelo. Mesmo ap\xF3s o passar do tempo, elas
    permanecem como marcas vis\xEDveis da arquitetura e da mem\xF3ria hist\xF3rica
    da regi\xE3o.\nAo observar essas estruturas, \xE9 poss\xEDvel compreender um
    pouco da import\xE2ncia que o complexo teve para o desenvolvimento comercial
    e cultural da cidade."
  m_isRightToLeft: 0
